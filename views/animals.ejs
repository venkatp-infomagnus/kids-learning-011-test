<!--
  animals.ejs
  Purpose: Displays a grid of animals with their names and sounds for a kids learning application.
  Usage: Rendered by the server to provide an interactive animal learning experience.
-->

<div class="section-header">
    <h2>Animals</h2>
</div>
<div class="animals-grid">
    <div class="animal-card">
        <div class="animal-image" data-animal="lion"></div>
        <div class="animal-name">Lion</div>
        <div class="animal-sound">Roar</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="elephant"></div>
        <div class="animal-name">Elephant</div>
        <div class="animal-sound">Trumpet</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="giraffe"></div>
        <div class="animal-name">Giraffe</div>
        <div class="animal-sound">Bleat</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="monkey"></div>
        <div class="animal-name">Monkey</div>
        <div class="animal-sound">Chatter</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="zebra"></div>
        <div class="animal-name">Zebra</div>
        <div class="animal-sound">Bark</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="penguin"></div>
        <div class="animal-name">Penguin</div>
        <div class="animal-sound">Honk</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="cat"></div>
        <div class="animal-name">Cat</div>
        <div class="animal-sound">Meow</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="dog"></div>
        <div class="animal-name">Dog</div>
        <div class="animal-sound">Woof</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="cow"></div>
        <div class="animal-name">Cow</div>
        <div class="animal-sound">Moo</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="sheep"></div>
        <div class="animal-name">Sheep</div>
        <div class="animal-sound">Baa</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="horse"></div>
        <div class="animal-name">Horse</div>
        <div class="animal-sound">Neigh</div>
    </div>
    <div class="animal-card">
        <div class="animal-image" data-animal="duck"></div>
        <div class="animal-name">Duck</div>
        <div class="animal-sound">Quack</div>
    </div>
</div>

<div class="learning-tips">
    <h3>Learning Tips</h3>
    <ul>
        <li>Practice animal sounds together</li>
        <li>Discuss where each animal lives</li>
        <li>Talk about what each animal eats</li>
    </ul>
</div>